# --- DATABASE ---
# Gunakan URL pooler Supabase (Transaction mode / pgbouncer) untuk runtime
# Format Supabase: postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5
DATABASE_URL="postgresql://user:password@host:6543/taskflow_db?pgbouncer=true&connection_limit=5"

# Gunakan URL direct (Session mode) HANYA untuk prisma migrate / prisma studio
# Format Supabase: postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://user:password@host:5432/taskflow_db"

# --- AUTH ---
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# --- SERVER ---
PORT=5000

# ⚠️ WAJIB diisi di environment production:
# - NODE_ENV=production mengaktifkan scheduleCleanup() otomatis (activity_logs & notifications)
# - Tanpa ini cleanup tidak akan pernah jalan meski server berjalan normal
# - Nilai: development | production
NODE_ENV=development

FRONTEND_URL="http://localhost:5173"
